generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum GameStatus {
  SCHEDULED
  READY
  PUBLISHED
  SKIPPED
}

model Game {
  id            String     @id @default(cuid())
  espnEventId   String     @unique
  homeTeam      String
  awayTeam      String
  homeTeamAbbr  String
  awayTeamAbbr  String
  scheduledAt   DateTime
  sport         String     // e.g. "mlb"
  status        GameStatus @default(SCHEDULED)

  // Odds (from external odds provider)
  spreadHome      Float?
  spreadAway      Float?
  spreadHomePrice Int?
  spreadAwayPrice Int?
  moneylineHome   Int?
  moneylineAway   Int?
  total           Float?
  overPrice       Int?
  underPrice      Int?

  // Pitchers / game-specific info
  homePitcher      String?
  awayPitcher      String?
  homePitcherStats Json?
  awayPitcherStats Json?

  // Team season stats (from ESPN)
  homeStats Json?
  awayStats Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article Article?
}

model Article {
  id                String   @id @default(cuid())
  gameId            String   @unique
  slug              String   @unique
  title             String
  metaDescription   String
  content           String   @db.Text
  pick              String   // e.g. "Dodgers -1.5"
  sport             String
  publishedAt       DateTime @default(now())
  featuredImageUrl  String?
  imageAlt          String?
  imageCredit       String?
  author            String?
  viewCount         Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  game Game @relation(fields: [gameId], references: [id])
}
