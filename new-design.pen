                    {
                      "type": "text",
                      "id": "GoH1i",
                      "name": "H2 1",
                      "fill": "#1A1A1A",
                      "content": "Why the Dodgers Have the Edge",
                      "fontFamily": "Playfair Display",
                      "fontSize": 22,
                      "fontWeight": "700"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "qtYei",
                  "name": "P1 Wrap",
                  "width": "fill_container",
                  "children": [
                    {
                      "type": "text",
                      "id": "QZtzF",
                      "name": "P1",
                      "fill": "#4B5563",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Yamamoto has been virtually untouchable at home and in NL parks this season. His 2.87 ERA ranks fifth in the NL, and he's allowing fewer than seven hits per nine innings. More importantly, he owns a 0.91 ERA in his last three starts. The Dodgers' lineup, meanwhile, ranks third in the NL in runs scored and features four batters hitting .280 or better against left-handed pitching.",
                      "lineHeight": 1.75,
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "T1LRm",
                  "name": "Art Ad 2",
